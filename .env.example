# Copy this file to `.env`, then uncomment one profile below.

# ------------------------------
# Profile A: cheap cloud testing
# ------------------------------
# OpenAI example:
# export OPENAI_API_KEY=sk-proj-...
# export LLM_API_KEY="${OPENAI_API_KEY}"
# export LLM_BASE_URL=https://api.openai.com/v1
# export LLM_MODEL=gpt-5.4-nano
# export LLM_PARALLEL=4
# export LLM_TEMPERATURE=0
# export LLM_TOP_P=1
# export LLM_PROMPT_CACHE_KEY_PREFIX=dem-labeling
# export LLM_PROMPT_CACHE_RETENTION=24h

# OpenRouter example:
# export OPENROUTER_API_KEY=sk-or-...
# export LLM_API_KEY="${OPENROUTER_API_KEY}"
# export LLM_BASE_URL=https://openrouter.ai/api/v1
# export LLM_MODEL=openai/gpt-4.1-nano
# export LLM_PARALLEL=4
# export LLM_TEMPERATURE=0
# export LLM_TOP_P=1

# ------------------------------
# Profile B: remote llama server
# ------------------------------
# export LLM_BASE_URL=
# export LLM_API_KEY=sk-no-key
# export LLM_MODEL=ggpl
# export LLM_PARALLEL=8
# export LLM_TEMPERATURE=0
# export LLM_TOP_P=0

# Default server discovery for multi-port llama scripts
export LLM_BASE_HOST=127.0.0.1
export LLM_BASE_PORT=8080
export LLM_MAX_PORTS_TO_SCAN=8

# Example remote host for rsync/ssh deployment
export REMOTE_HOST=your-user@your-gpu-server
export REMOTE_APP_DIR=~/dem
